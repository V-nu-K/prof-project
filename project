def generate_password():
    print("\n--- PASSWORD GENERATION ---")
    
    try:
        length = int(input("Enter password length (6 to 30): "))
        if length < 6:
            length = 6
            print("Too short. Set to 6 characters.")
        if length > 30:
            length = 30
            print("Too long. Set to 30 characters.")
    except:
        length = 12
        print("Error! Set to 12 characters.")
